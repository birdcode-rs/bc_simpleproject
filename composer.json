{
    "name": "birdcode/bc-simpleproject",
    "license": "GPL-2.0-or-later",
    "type": "typo3-cms-extension",
    "description": "Additional items for your project",
    "keywords": [
        "TYPO3",
        "extension",
        "project"
    ],
    "homepage": "https://extensions.typo3.org/extension/bc_simpleproject",
    "support": {
        "source": "https://github.com/birdcode-rs/bc_simpleproject",
        "issues": "https://github.com/birdcode-rs/bc_simpleproject/issues"
    },
    "authors": [
        {
            "name": "Bird Dev",
            "role": "Developer",
            "email": "bird.dev@birdcode.in.rs",
            "homepage": "https://birdcode.tech"
        }
    ], 
    "require": {
        "php": ">= 8.0 < 8.4", 
        "typo3/cms-backend": "^13|| ^14",
        "typo3/cms-core": "^13 || ^14",
        "typo3/cms-extbase": "^13 || ^14",
        "typo3/cms-frontend": "^13 || ^14",
        "typo3/cms-fluid": "^13 || ^14"
    },
    "suggest": {
        "friendsoftypo3/headless": "TYPO3 Headless API"
    },
    "autoload": {
        "psr-4": {
            "BirdCode\\BcSimpleproject\\": "Classes"
        }
    },
    "config": {
        "vendor-dir": ".Build/vendor",
        "bin-dir": ".Build/bin",
        "lock": false,
        "allow-plugins": {
            "typo3/class-alias-loader": true,
            "typo3/cms-composer-installers": true
        }
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "bc_simpleproject",
            "app-dir": ".Build",
            "web-dir": ".Build/Web"
        }
    }
}